{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build",
            "type": "shell",
            "command": "make",
            "args": ["all"],
            "options": { "cwd": "${workspaceFolder}/ticlang" },
            "group": { "kind": "build", "isDefault": true },
            "problemMatcher": ["$gcc"],
            "detail": "增量编译"
        },
        {
            "label": "Rebuild",
            "type": "shell",
            "command": "make clean && make all",
            "options": { "cwd": "${workspaceFolder}/ticlang" },
            "problemMatcher": ["$gcc"],
            "detail": "清理后重新编译"
        },
        {
            "label": "Clean",
            "type": "shell",
            "command": "make",
            "args": ["clean"],
            "options": { "cwd": "${workspaceFolder}/ticlang" },
            "problemMatcher": [],
            "detail": "清理编译产物"
        }
    ]
}
